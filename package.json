{
  "name": "lost-found-mern",
  "version": "2.0.0",
  "description": "Lost & Found MERN Stack Application - Updated February 2026",
  "main": "index.js",
  "scripts": {
    "install-all": "cd server && npm install && cd ../client && npm install && cd ..",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": [
    "mern",
    "lost-found",
    "mongodb",
    "express",
    "react",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
